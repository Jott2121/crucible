import io
import sys

import pytest

from idna.cli import _build_parser, _convert_one, _iter_stdin, _looks_like_alabel, main
from idna.package_data import __version__


# ---------------------------------------------------------------------------
# _looks_like_alabel
# ---------------------------------------------------------------------------

def test_looks_like_alabel_simple_true():
    assert _looks_like_alabel("xn--n3h") is True


def test_looks_like_alabel_simple_false():
    assert _looks_like_alabel("example.com") is False


def test_looks_like_alabel_multi_label_true():
    assert _looks_like_alabel("www.xn--n3h.com") is True


def test_looks_like_alabel_case_insensitive():
    assert _looks_like_alabel("XN--N3H") is True


def test_looks_like_alabel_empty_string():
    assert _looks_like_alabel("") is False


def test_looks_like_alabel_all_dots():
    assert _looks_like_alabel("..") is False


def test_looks_like_alabel_unicode_dot_separator():
    assert _looks_like_alabel("abc\u3002xn--n3h") is True


def test_looks_like_alabel_no_prefix_multi_label():
    assert _looks_like_alabel("foo.bar.baz") is False


# ---------------------------------------------------------------------------
# _build_parser
# ---------------------------------------------------------------------------

def test_build_parser_defaults():
    parser = _build_parser()
    args = parser.parse_args([])
    assert args.mode is None
    assert args.strict is False
    assert args.domain == []


def test_build_parser_encode_flag():
    parser = _build_parser()
    args = parser.parse_args(["-e", "example.com"])
    assert args.mode == "encode"
    assert args.domain == ["example.com"]


def test_build_parser_decode_flag_long_form():
    parser = _build_parser()
    args = parser.parse_args(["--decode", "example.com"])
    assert args.mode == "decode"


def test_build_parser_strict_flag():
    parser = _build_parser()
    args = parser.parse_args(["--strict", "example.com"])
    assert args.strict is True


def test_build_parser_multiple_domains():
    parser = _build_parser()
    args = parser.parse_args(["a.com", "b.com", "c.com"])
    assert args.domain == ["a.com", "b.com", "c.com"]


def test_build_parser_mutually_exclusive_encode_decode():
    parser = _build_parser()
    with pytest.raises(SystemExit) as excinfo:
        parser.parse_args(["-e", "-d", "example.com"])
    assert excinfo.value.code == 2


def test_build_parser_version(capsys):
    parser = _build_parser()
    with pytest.raises(SystemExit) as excinfo:
        parser.parse_args(["--version"])
    assert excinfo.value.code == 0
    captured = capsys.readouterr()
    assert captured.out.strip() == f"idna {__version__}"


# ---------------------------------------------------------------------------
# _iter_stdin
# ---------------------------------------------------------------------------

def test_iter_stdin_skips_blank_lines():
    stream = io.StringIO("a\n\nb\n   \nc\n")
    assert list(_iter_stdin(stream)) == ["a", "b", "c"]


def test_iter_stdin_empty_stream():
    stream = io.StringIO("")
    assert list(_iter_stdin(stream)) == []


def test_iter_stdin_strips_whitespace_and_crlf():
    stream = io.StringIO("  foo  \r\nbar\r\n")
    assert list(_iter_stdin(stream)) == ["foo", "bar"]


def test_iter_stdin_only_blank_lines():
    stream = io.StringIO("\n\n   \n\t\n")
    assert list(_iter_stdin(stream)) == []


# ---------------------------------------------------------------------------
# _convert_one
# ---------------------------------------------------------------------------

def test_convert_one_encode_success(capsys):
    result = _convert_one("\u2603", "encode", True)
    assert result is True
    captured = capsys.readouterr()
    assert captured.out == "xn--n3h\n"
    assert captured.err == ""


def test_convert_one_decode_success(capsys):
    result = _convert_one("xn--n3h", "decode", True)
    assert result is True
    captured = capsys.readouterr()
    assert captured.out == "\u2603\n"
    assert captured.err == ""


def test_convert_one_encode_failure_label_too_long(capsys):
    domain = "a" * 64
    result = _convert_one(domain, "encode", True)
    assert result is False
    captured = capsys.readouterr()
    assert captured.out == ""
    assert captured.err.startswith(f"idna: encode failed for {domain!r}:")


def test_convert_one_ascii_passthrough_on_encode(capsys):
    result = _convert_one("example.com", "encode", True)
    assert result is True
    captured = capsys.readouterr()
    assert captured.out == "example.com\n"


# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

def test_main_encode_plain_ascii(capsys):
    rc = main(["example.com"])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == "example.com\n"


def test_main_encode_unicode_snowman(capsys):
    rc = main(["\u2603"])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == "xn--n3h\n"


def test_main_decode_inferred_from_alabel(capsys):
    rc = main(["xn--n3h"])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == "\u2603\n"


def test_main_explicit_encode_overrides_alabel_look(capsys):
    rc = main(["-e", "xn--n3h"])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == "xn--n3h\n"


def test_main_multiple_domains_mode_from_first(capsys):
    rc = main(["\u2603", "xn--n3h"])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == "xn--n3h\nxn--n3h\n"


def test_main_failure_returns_1(capsys):
    domain = "a" * 64
    rc = main([domain])
    assert rc == 1
    captured = capsys.readouterr()
    assert captured.out == ""
    assert "idna: encode failed for" in captured.err


def test_main_partial_failure_returns_1(capsys):
    domain = "a" * 64
    rc = main(["short", domain])
    assert rc == 1
    captured = capsys.readouterr()
    assert captured.out == "short\n"
    assert "idna: encode failed for" in captured.err


def test_main_no_domain_empty_stdin_returns_0(capsys, monkeypatch):
    monkeypatch.setattr(sys, "stdin", io.StringIO(""))
    rc = main([])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == ""


def test_main_reads_from_stdin(capsys, monkeypatch):
    monkeypatch.setattr(sys, "stdin", io.StringIO("\u2603\nxn--n3h\n"))
    rc = main([])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == "xn--n3h\nxn--n3h\n"


def test_main_stdin_blank_lines_ignored(capsys, monkeypatch):
    monkeypatch.setattr(sys, "stdin", io.StringIO("\n\nexample.com\n\n"))
    rc = main([])
    assert rc == 0
    captured = capsys.readouterr()
    assert captured.out == "example.com\n"


def test_main_errors_when_no_domain_and_stdin_is_tty(monkeypatch):
    class FakeTTYStdin:
        def isatty(self):
            return True

        def __iter__(self):
            return iter([])

    monkeypatch.setattr(sys, "stdin", FakeTTYStdin())
    with pytest.raises(SystemExit) as excinfo:
        main([])
    assert excinfo.value.code == 2
