import pytest

from graph_guard.ppr import personalized_pagerank


def test_duplicate_seeds_receive_their_combined_teleport_probability():
    result = personalized_pagerank(
        {"seed": {}},
        ["seed", "seed"],
        alpha=0.5,
        iters=1,
        tol=0.0,
    )

    # The sole node is dangling, so all probability mass must return to the
    # (duplicated, but still sole) personalized seed.
    assert result["seed"] == pytest.approx(1.0, rel=1e-12)


def test_default_iteration_count_is_fifty_when_tolerance_cannot_stop_early():
    alpha = 0.99
    result = personalized_pagerank(
        {"a": {"b": 1.0}, "b": {}},
        ["a"],
        alpha=alpha,
        tol=0.0,
    )

    # Independently iterate the two-state recurrence for exactly the documented
    # default of 50 iterations.  If r is rank(a), then rank(a)' = 1 - alpha*r.
    expected_a = 0.5
    for _ in range(50):
        expected_a = 1.0 - alpha * expected_a

    assert result["a"] == pytest.approx(expected_a, rel=1e-10)
    assert result["b"] == pytest.approx(1.0 - expected_a, rel=1e-10)


def test_convergence_delta_uses_difference_not_sum():
    result = personalized_pagerank(
        {"a": {"b": 1.0}, "b": {}},
        ["a"],
        alpha=0.5,
        iters=2,
        tol=0.6,
    )

    # Initial ranks are (0.5, 0.5).  One iteration yields (0.75, 0.25),
    # whose L1 change is 0.5, so it must stop under tol=0.6.
    assert result["a"] == pytest.approx(0.75, rel=1e-12)
    assert result["b"] == pytest.approx(0.25, rel=1e-12)


def test_equality_with_tolerance_does_not_stop_iteration():
    result = personalized_pagerank(
        {"a": {"b": 1.0}, "b": {}},
        ["a"],
        alpha=0.5,
        iters=2,
        tol=0.5,
    )

    # The first L1 delta is exactly 0.5.  The strict comparison requires a
    # second iteration, which yields (0.625, 0.375).
    assert result["a"] == pytest.approx(0.625, rel=1e-12)
    assert result["b"] == pytest.approx(0.375, rel=1e-12)


class _HashChangingNode:
    def __init__(self, name):
        self.name = name
        self.hash_value = hash(name)

    def __hash__(self):
        return self.hash_value

    def __eq__(self, other):
        return self is other


class _HashFlippingAdjacency(dict):
    """Changes key hashes after out_sum has been built."""

    def __init__(self, first, second):
        super().__init__({first: {}, second: {}})
        self._nodes = (first, second)
        self._get_calls = 0

    def get(self, key, default=None):
        value = super().get(key, default)
        self._get_calls += 1
        # There are exactly two get calls while constructing out_sum.
        if self._get_calls == 2:
            for node in self._nodes:
                node.hash_value += 1000003
        return value


def test_missing_out_sum_entries_are_treated_as_dangling_nodes():
    first = _HashChangingNode("first")
    second = _HashChangingNode("second")
    adjacency = _HashFlippingAdjacency(first, second)

    result = personalized_pagerank(
        adjacency,
        [first],
        alpha=0.5,
        iters=1,
        tol=0.0,
    )

    # Both rows are empty.  Even if an out_sum lookup misses, its fallback is
    # zero and both initial ranks are dangling, returning all mass to first.
    assert result[first] == pytest.approx(1.0, rel=1e-12)
    assert result[second] == pytest.approx(0.0, abs=1e-12)


class _ExpiringRowsAdjacency(dict):
    """Supplies a positive row while sums are built, then only supplied defaults."""

    def __init__(self):
        super().__init__({"source": {}, "sink": {}})
        self._sum_phase_calls = 0

    def get(self, key, default=None):
        if self._sum_phase_calls < 2:
            self._sum_phase_calls += 1
            if key == "source":
                return {"sink": 1.0}
            return {}
        return default


def test_missing_adjacency_row_uses_empty_dict_default():
    adjacency = _ExpiringRowsAdjacency()

    result = personalized_pagerank(
        adjacency,
        ["source"],
        alpha=0.5,
        iters=1,
        tol=0.0,
    )

    # source had positive recorded out-weight but its row subsequently expires.
    # The empty-dict fallback means it emits no edge mass; sink is dangling and
    # the resulting teleport mass is 0.5 at source.
    assert result["source"] == pytest.approx(0.5, rel=1e-12)
    assert result["sink"] == pytest.approx(0.0, abs=1e-12)
