import json
import warnings

import numpy as np
import pandas as pd
import pytest

import train


class PredictingPipe:
    def __init__(self, probabilities):
        self.probabilities = np.asarray(probabilities)
        self.fit_arguments = None

    def fit(self, X, y):
        self.fit_arguments = (X, y)
        return self

    def predict_proba(self, X):
        return np.column_stack([1.0 - self.probabilities, self.probabilities])


def test_evaluate_uses_five_explicit_stratified_folds_and_computes_metrics(monkeypatch):
    X_train = pd.DataFrame({"feature": range(10)})
    y_train = pd.Series([0, 1] * 5)
    X_test = pd.DataFrame({"feature": range(4)})
    y_test = pd.Series([0, 0, 1, 1])
    pipe = PredictingPipe([0.1, 0.6, 0.8, 0.4])

    created_cv = []

    def stratified_kfold(*, n_splits=None, shuffle=False, random_state=None):
        created_cv.append((n_splits, shuffle, random_state))
        return object()

    def cross_validate(received_pipe, received_X, received_y, scoring, cv, n_jobs):
        assert received_pipe is pipe
        assert received_X is X_train
        assert received_y is y_train
        assert scoring == "roc_auc"
        assert cv is not None
        assert n_jobs == -1
        return np.array([0.7, 0.9])

    monkeypatch.setattr(train, "StratifiedKFold", stratified_kfold)
    monkeypatch.setattr(train, "cross_val_score", cross_validate)

    result = train.evaluate("demo", pipe, X_train, X_test, y_train, y_test)

    assert pipe.fit_arguments == (X_train, y_train)
    assert created_cv == [(5, True, train.RANDOM_STATE)]
    assert result.name == "demo"
    assert result.roc_auc == pytest.approx(0.75, rel=1e-6)
    assert result.pr_auc == pytest.approx(0.75, rel=1e-6)
    assert result.f1 == pytest.approx(0.5, rel=1e-6)
    assert result.precision == pytest.approx(0.5, rel=1e-6)
    assert result.recall == pytest.approx(0.5, rel=1e-6)
    assert result.brier == pytest.approx(0.1925, rel=1e-6)
    assert result.cv_roc_auc_mean == pytest.approx(0.8, rel=1e-6)
    assert result.cv_roc_auc_std == pytest.approx(0.1, rel=1e-6)
    assert result.confusion.tolist() == [[1, 1], [1, 1]]


def test_evaluate_silently_assigns_zero_precision_when_nothing_is_predicted(
    monkeypatch,
):
    X_train = pd.DataFrame({"feature": range(10)})
    y_train = pd.Series([0, 1] * 5)
    X_test = pd.DataFrame({"feature": range(4)})
    y_test = pd.Series([0, 1, 0, 1])
    pipe = PredictingPipe([0.1, 0.2, 0.3, 0.4])

    monkeypatch.setattr(
        train,
        "StratifiedKFold",
        lambda **kwargs: object(),
    )
    monkeypatch.setattr(
        train,
        "cross_val_score",
        lambda *args, **kwargs: np.array([0.6, 0.8]),
    )
    monkeypatch.setattr(train, "classification_report", lambda *args, **kwargs: "report")

    with warnings.catch_warnings(record=True) as caught:
        warnings.simplefilter("always")
        result = train.evaluate("no-positive-predictions", pipe, X_train, X_test, y_train, y_test)

    assert caught == []
    assert result.precision == pytest.approx(0.0, rel=1e-6)
    assert result.recall == pytest.approx(0.0, rel=1e-6)


def test_run_builds_expected_pipelines_selects_best_and_persists_outputs(
    monkeypatch, tmp_path, capsys
):
    X = pd.DataFrame({"feature": range(10)})
    y = pd.Series([0, 1] * 5)
    X_train = X.iloc[:8]
    X_test = X.iloc[8:]
    y_train = y.iloc[:8]
    y_test = y.iloc[8:]

    preprocessors = []
    pipelines = []
    evaluations = []
    dumps = []

    estimators = {
        "a": object(),
        "z": object(),
        "m": object(),
    }
    scores = {"a": 0.9, "z": 0.1, "m": 0.2}

    class FakeResult:
        def __init__(self, name, pipeline):
            self.name = name
            self.pipeline = pipeline
            self.roc_auc = scores[name]
            self.pr_auc = 0.4
            self.f1 = 0.3
            self.precision = 0.2
            self.recall = 0.1
            self.brier = 0.05
            self.cv_roc_auc_mean = 0.6
            self.cv_roc_auc_std = 0.07
            self.confusion = np.array([[3, 1], [1, 3]])

        def to_dict(self):
            return {
                "name": self.name,
                "roc_auc": self.roc_auc,
                "pr_auc": self.pr_auc,
                "f1": self.f1,
                "precision": self.precision,
                "recall": self.recall,
                "brier": self.brier,
                "cv_roc_auc_mean": self.cv_roc_auc_mean,
                "cv_roc_auc_std": self.cv_roc_auc_std,
                "confusion": [[3, 1], [1, 3]],
            }

    def load_data():
        return X, y, {"ignored": True}

    def split_data(received_X, received_y, **kwargs):
        assert received_X is X
        assert received_y is y
        assert kwargs == {
            "test_size": 0.2,
            "stratify": y,
            "random_state": train.RANDOM_STATE,
        }
        return X_train, X_test, y_train, y_test

    def build_preprocessor(received_X):
        assert received_X is X_train
        preprocessor = object()
        preprocessors.append(preprocessor)
        return preprocessor

    def make_pipeline(*, steps):
        expected = [
            ("preprocess", preprocessors[-1]),
            ("model", estimators[len(pipelines) == 0 and "a" or len(pipelines) == 1 and "z" or "m"]),
        ]
        assert steps == expected
        pipeline = object()
        pipelines.append(pipeline)
        return pipeline

    def evaluate(name, pipeline, received_X_train, received_X_test, received_y_train, received_y_test):
        assert name in estimators
        assert pipeline is pipelines[len(evaluations)]
        assert received_X_train is X_train
        assert received_X_test is X_test
        assert received_y_train is y_train
        assert received_y_test is y_test
        evaluations.append(name)
        return FakeResult(name, pipeline)

    def dump(value, path):
        dumps.append((value, path))

    monkeypatch.setattr(train, "load_and_prepare", load_data)
    monkeypatch.setattr(train, "train_test_split", split_data)
    monkeypatch.setattr(train, "build_preprocessor", build_preprocessor)
    monkeypatch.setattr(train, "Pipeline", make_pipeline)
    monkeypatch.setattr(train, "_candidates", lambda: estimators)
    monkeypatch.setattr(train, "evaluate", evaluate)
    monkeypatch.setattr(train.joblib, "dump", dump)
    monkeypatch.setattr(train, "MODELS_DIR", tmp_path / "models")
    monkeypatch.setattr(train, "REPORTS_DIR", tmp_path / "reports")
    train.REPORTS_DIR.mkdir()

    results = train.run()

    assert list(results) == ["a", "z", "m"]
    assert evaluations == ["a", "z", "m"]
    assert len(preprocessors) == 3
    assert dumps == [
        (results["a"].pipeline, train.MODELS_DIR / "best_model.joblib"),
        ("a", train.MODELS_DIR / "best_model_name.joblib"),
    ]

    expected_metrics = {name: results[name].to_dict() for name in ["a", "z", "m"]}
    metrics_path = train.REPORTS_DIR / "metrics.json"
    assert metrics_path.read_text() == json.dumps(expected_metrics, indent=2)
    assert json.loads(metrics_path.read_text()) == expected_metrics

    output = capsys.readouterr().out
    assert "Train: 8 rows (50.0% positive) | Test: 2 rows (50.0% positive)" in output
    assert "=== a ===" in output
    assert "ROC-AUC: 0.900" in output
    assert "CV ROC-AUC (5-fold): 0.600 ± 0.070" in output
    assert "Best model: a (ROC-AUC = 0.900)" in output
    assert f"Saved model → {train.MODELS_DIR / 'best_model.joblib'}" in output
    assert f"Saved metrics → {train.REPORTS_DIR / 'metrics.json'}" in output
