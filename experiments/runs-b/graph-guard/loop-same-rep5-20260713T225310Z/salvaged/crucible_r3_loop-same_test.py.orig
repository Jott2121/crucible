import math
import pytest

from graph_guard.ppr import personalized_pagerank


def test_dangling_nodes_redistribute_all_mass_to_seed():
    # Both nodes have zero out-degree -> every step is fully dangling.
    # All mass must be teleported back onto the sole seed "A" each iteration,
    # so the fixed point is rank_A = 1.0, rank_B = 0.0 exactly.
    adj = {"A": {}, "B": {}}
    rank = personalized_pagerank(adj, seeds=["A"])
    assert rank["A"] == pytest.approx(1.0, abs=1e-6)
    assert rank["B"] == pytest.approx(0.0, abs=1e-6)
    assert sum(rank.values()) == pytest.approx(1.0, rel=1e-6)


def test_two_node_cycle_personalized_on_one_node():
    # A <-> B, full weight both ways, personalized on A only.
    # Fixed point: rank_A = 1/(1+alpha), rank_B = alpha/(1+alpha).
    alpha = 0.85
    adj = {"A": {"B": 1.0}, "B": {"A": 1.0}}
    rank = personalized_pagerank(adj, seeds=["A"], alpha=alpha)

    expected_a = 1.0 / (1.0 + alpha)
    expected_b = alpha / (1.0 + alpha)

    assert rank["A"] == pytest.approx(expected_a, rel=1e-6)
    assert rank["B"] == pytest.approx(expected_b, rel=1e-6)
    assert sum(rank.values()) == pytest.approx(1.0, rel=1e-6)


def test_hub_with_dangling_neighbors_weighted_split():
    # A points to B (weight 2) and C (weight 1); B and C have no outgoing
    # edges of their own (C never even appears as a top-level key in adj,
    # exercising the default branch of adj.get(u, {}) and out_sum.get(u, ...)).
    # Seed only on A.
    alpha = 0.85
    adj = {"A": {"B": 2.0, "C": 1.0}}
    rank = personalized_pagerank(adj, seeds=["A"], alpha=alpha)

    # Derived analytically (fixed point of the iteration):
    # rank_A = 1 / (1 + alpha)
    # rank_B = alpha * rank_A * (2/3)
    # rank_C = alpha * rank_A * (1/3)
    rank_a = 1.0 / (1.0 + alpha)
    rank_b = alpha * rank_a * (2.0 / 3.0)
    rank_c = alpha * rank_a * (1.0 / 3.0)

    assert rank["A"] == pytest.approx(rank_a, rel=1e-6)
    assert rank["B"] == pytest.approx(rank_b, rel=1e-6)
    assert rank["C"] == pytest.approx(rank_c, rel=1e-6)
    assert sum(rank.values()) == pytest.approx(1.0, rel=1e-6)
    # B should get twice the mass of C given the 2:1 weight split.
    assert rank["B"] == pytest.approx(2.0 * rank["C"], rel=1e-6)
