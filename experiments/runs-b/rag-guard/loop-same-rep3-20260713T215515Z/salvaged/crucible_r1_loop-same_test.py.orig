import pytest

from rag_guard.guard import _content_tokens, groundedness, redact_pii


def test_content_tokens_empty_string_returns_empty_set():
    # An empty string should yield no tokens at all.
    # The mutant replaces the empty-string fallback with "XXXX",
    # which would produce a non-empty token set.
    assert _content_tokens("") == set()


def test_groundedness_support_rounds_to_four_decimals():
    # 1 out of 3 content words supported -> support = 1/3
    answer = "alpha beta gamma"
    contexts = ["alpha"]
    result = groundedness(answer, contexts, threshold=0.5)
    expected = round(1 / 3, 4)  # 0.3333
    assert result["support"] == pytest.approx(expected, rel=1e-6)
    # Distinguish from rounding to 5 decimals (0.33333), which the mutant produces.
    assert result["support"] != round(1 / 3, 5)


def test_redact_pii_card_number_exact_replacement():
    text = "Card: 1234567890123456 end"
    result = redact_pii(text)
    assert result == "Card: [redacted-card] end"
